# ========================================
# SMART CITY SYSTEM - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your API keys

# ========================================
# Admin Credentials (CHANGE THESE!)
# ========================================
ADMIN_USERNAME=smartcity_admin
ADMIN_PASSWORD=Admin@123

# ========================================
# Real-Time Air Quality APIs
# ========================================

# WAQI API Token (Recommended)
# Get free token at: https://aqicn.org/data-platform/token
WAQI_TOKEN=your_waqi_token_here

# OpenWeatherMap API Key (Fallback)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_KEY=your_openweather_api_key_here

# ========================================
# Flask Configuration
# ========================================
FLASK_ENV=development
FLASK_DEBUG=True

# ========================================
# Database Configuration (if needed)
# ========================================
# DATABASE_URL=

# ========================================
# Other Configuration
# ========================================
# Add more variables as needed for your setup
